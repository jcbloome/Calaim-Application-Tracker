# -----------------------------------------------------------------------------
# CalAIM Tracker - Local Environment Template
# Copy to .env.local (recommended) or .env.development for local development.
# Never commit real secrets.
# -----------------------------------------------------------------------------

# App environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# Public client config (safe to expose to browser, but still environment-specific)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-2881432245-f1d94
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studio-2881432245-f1d94.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=
NEXT_PUBLIC_CASPIO_BASE_URL=

# Optional desktop installer metadata (display only)
NEXT_PUBLIC_DESKTOP_INSTALLER_URL=
NEXT_PUBLIC_DESKTOP_INSTALLER_VERSION=

# -----------------------------------------------------------------------------
# Server-only (web runtime)
# -----------------------------------------------------------------------------
CASPIO_BASE_URL=
CASPIO_CLIENT_ID=
CASPIO_CLIENT_SECRET=
CASPIO_TABLE_NAME=CalAIM_tbl_Members
CASPIO_WEBHOOK_SECRET=
CASPIO_READ_ONLY=false

RESEND_API_KEY=
EMAIL_FROM=CalAIM Pathfinder <noreply@carehomefinders.com>
H2022_REJECTION_CC=
H2022_REJECTION_BCC=

CRON_SECRET=

GOOGLE_MAPS_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_API_KEY=

# Firebase Admin / service credentials (local or self-hosted contexts only)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=studio-2881432245-f1d94
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=studio-2881432245-f1d94.firebasestorage.app
FIREBASE_CONFIG=

# AI / extraction (optional)
GEMINI_API_KEY=
FIREBASE_API_KEY=
ANTHROPIC_API_KEY=

# Desktop app runtime (Electron)
DESKTOP_APP_URL=
DESKTOP_UPDATE_URL=
DESKTOP_SHOW_DEBUG=0
DESKTOP_INSTALLER_VERSION=
CALAIM_DESKTOP_URL=

# macOS desktop notarization (desktop build pipeline)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# -----------------------------------------------------------------------------
# Firebase Functions secrets (set with firebase functions:secrets:set)
# These should not be stored in local env files for production use.
# -----------------------------------------------------------------------------
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# SENDGRID_API_KEY=
# FUNCTIONS_EMULATOR=true
