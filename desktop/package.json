{
  "name": "calaim-desktop",
  "version": "3.0.26",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "electron dist/main.js",
    "dev": "npm run build && electron dist/main.js",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "publish:win": "npm run dist:win && node -e \"const v=require('./package.json').version; const {execSync}=require('child_process'); const exe=`release/Connect-CalAIM-Desktop-win-${v}.exe`; const blockmap=`${exe}.blockmap`; const cmd=`gh release upload v${v} \\\"${exe}\\\" \\\"${blockmap}\\\" \\\"release/latest.yml\\\" --clobber`; execSync(cmd,{stdio:'inherit'});\"",
    "publish:mac": "npm run dist:mac && node -e \"const v=require('./package.json').version; const {execSync}=require('child_process'); const dmg=`release/Connect-CalAIM-Desktop-mac-${v}.dmg`; const zip=`release/Connect-CalAIM-Desktop-mac-${v}.zip`; const cmd=`gh release upload v${v} \\\"${dmg}\\\" \\\"${zip}\\\" --clobber`; execSync(cmd,{stdio:'inherit'});\""
  },
  "build": {
    "appId": "com.connectionsilos.calaimdesktop",
    "productName": "Connect CalAIM Desktop",
    "artifactName": "Connect-CalAIM-Desktop-${os}-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "assets/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/tray.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.medical",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "afterSign": "scripts/notarize.js",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Connect CalAIM Desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jcbloome",
        "repo": "Calaim-Application-Tracker"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@types/node": "^20",
    "electron": "^32.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5"
  }
}
